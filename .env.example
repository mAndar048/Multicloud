# Core
ENV=development
LOG_LEVEL=INFO

# API keys
LLM_FALLBACK_MODE=mock
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_MOCK_RESPONSE=

# Terraform
TERRAFORM_BIN=terraform
CLOUDPILOT_WORKSPACE_ROOT=./.cloudpilot-workspaces
TF_STATE_BACKEND=local
TF_STATE_BUCKET=
TF_STATE_REGION=

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# AWS credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# GCP credentials
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# DigitalOcean credentials
DIGITALOCEAN_TOKEN=
